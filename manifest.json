{
  "manifest_version": 3,
  "name": "WhatsApp Sidebar",
  "version": "1.7",
  "permissions": ["sidePanel"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": {
    "default_title": "Open WhatsApp Web Messages",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
